# Plantilla de variables de entorno del SUT Sureno.
# Copia este archivo a .env y rellena los valores reales.
# El .env real NO se versiona (ver .gitignore) - fix DEF-001.

# Cadena de conexion a MongoDB Atlas (o Mongo local)
MONGO_URI=mongodb+srv://USUARIO:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# Nombre de la base de datos
MONGO_DB_NAME=Sureno

# Clave secreta de Flask (sesiones) - fix DEF-011
SECRET_KEY=cambia-esto-por-un-valor-aleatorio-largo

# Entorno Flask
FLASK_ENV=development
FLASK_DEBUG=0
