---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { Icon } from 'astro-icon/components';
import { apiServer } from '@/lib/api';
import DeleteDialog from '@/components/DeleteDialog.astro';

interface Product {
  _id: string;
  nombre: string;
  precio: number;
  stock?: number;
  mililitros?: number;
  categoria_id?: string;
  imagen?: string;
}
interface Category { _id: string; nombre: string; }

const [pRes, cRes] = await Promise.all([
  apiServer<Product[]>('/api/products', Astro.request),
  apiServer<Category[]>('/api/categories', Astro.request),
]);
const productos = pRes.data ?? [];
const categorias = cRes.data ?? [];
const catName = (id?: string) => categorias.find((c) => c._id === id)?.nombre ?? 'Sin categoría';

const inputClass =
  'w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none focus:border-slate-500 focus:ring-2 focus:ring-slate-200 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100 dark:focus:ring-slate-800';
---

<AdminLayout title="Productos — Sureño" active="products">
  <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-slate-900 dark:text-white">Productos</h1>
      <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Gestiona el catálogo, stock, precios e imágenes.</p>
    </div>
    <button type="button" data-open-create class="inline-flex items-center justify-center gap-2 rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white shadow-sm transition-colors hover:bg-slate-700 dark:bg-white dark:text-slate-950 dark:hover:bg-slate-200">
      <Icon name="lucide:plus" class="h-4 w-4" />
      Nuevo producto
    </button>
  </div>

  {productos.length === 0 ? (
    <div class="rounded-lg border border-dashed border-slate-300 bg-white p-10 text-center dark:border-slate-700 dark:bg-slate-900">
      <Icon name="lucide:package-open" class="mx-auto h-10 w-10 text-slate-400" />
      <p class="mt-3 font-medium">No hay productos.</p>
      <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Agrega el primer producto para iniciar el catálogo.</p>
    </div>
  ) : (
    <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm dark:border-slate-800 dark:bg-slate-900">
      <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
          <thead class="border-b border-slate-200 bg-slate-50 text-xs uppercase tracking-wide text-slate-500 dark:border-slate-800 dark:bg-slate-900/70 dark:text-slate-400">
            <tr>
              <th class="p-3">Producto</th>
              <th class="p-3">Precio</th>
              <th class="p-3">Stock</th>
              <th class="p-3">ml</th>
              <th class="p-3">Categoría</th>
              <th class="p-3 text-right">Acciones</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
            {productos.map((p) => (
              <tr data-row={p._id} class="hover:bg-slate-50 dark:hover:bg-slate-800/40">
                <td class="p-3">
                  <div class="flex items-center gap-3">
                    <img src={p.imagen || '/static/img/producto.png'} alt={p.nombre} class="h-12 w-12 rounded-md border border-slate-200 object-cover dark:border-slate-700" onerror="this.src='/static/img/producto.png'" />
                    <span class="font-medium text-slate-900 dark:text-white">{p.nombre}</span>
                  </div>
                </td>
                <td class="p-3 font-semibold">${Number(p.precio).toFixed(2)}</td>
                <td class="p-3">{p.stock ?? '—'}</td>
                <td class="p-3">{p.mililitros ?? '—'}</td>
                <td class="p-3">{catName(p.categoria_id)}</td>
                <td class="p-3">
                  <div class="flex justify-end gap-2">
                    <button
                      type="button"
                      class="inline-flex items-center gap-1.5 rounded-md border border-slate-200 px-2.5 py-1.5 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-100 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800"
                      data-edit={p._id}
                      data-nombre={p.nombre}
                      data-precio={p.precio}
                      data-stock={p.stock ?? ''}
                      data-mililitros={p.mililitros ?? ''}
                      data-categoria={p.categoria_id ?? ''}
                    >
                      <Icon name="lucide:pencil" class="h-4 w-4" />
                      Editar
                    </button>
                    <button
                      type="button"
                      class="inline-flex items-center gap-1.5 rounded-md border border-red-200 px-2.5 py-1.5 text-sm font-medium text-red-700 transition-colors hover:bg-red-50 dark:border-red-900/60 dark:text-red-300 dark:hover:bg-red-950/40"
                      data-del={p._id}
                      data-del-name={p.nombre}
                    >
                      <Icon name="lucide:trash-2" class="h-4 w-4" />
                      Eliminar
                    </button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  )}

  <dialog id="product-modal" class="fixed inset-0 m-auto max-h-[90vh] w-[min(92vw,760px)] overflow-y-auto rounded-lg border border-slate-200 bg-white p-0 text-slate-900 shadow-xl backdrop:bg-slate-950/50 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-100">
    <form id="product-form" class="p-6" enctype="multipart/form-data">
      <div class="mb-5 flex items-start justify-between gap-4">
        <div>
          <h2 data-form-title class="text-lg font-semibold">Nuevo producto</h2>
          <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Completa los datos del producto.</p>
        </div>
        <button type="button" data-modal-close class="grid h-9 w-9 place-items-center rounded-md text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-800" aria-label="Cerrar modal">
          <Icon name="lucide:x" class="h-5 w-5" />
        </button>
      </div>

      <input type="hidden" name="_id" />
      <div class="grid gap-4 sm:grid-cols-2">
        <label class="block text-sm"><span class="mb-1 block font-medium">Nombre</span><input name="nombre" required class={inputClass} /></label>
        <label class="block text-sm"><span class="mb-1 block font-medium">Precio</span><input name="precio" type="number" step="0.01" required class={inputClass} /></label>
        <label class="block text-sm"><span class="mb-1 block font-medium">Stock</span><input name="stock" type="number" required class={inputClass} /></label>
        <label class="block text-sm"><span class="mb-1 block font-medium">Mililitros</span><input name="mililitros" type="number" required class={inputClass} /></label>
        <label class="block text-sm">
          <span class="mb-1 block font-medium">Categoría</span>
          <select name="categoria_id" required class={inputClass}>
            <option value="">Selecciona…</option>
            {categorias.map((c) => <option value={c._id}>{c.nombre}</option>)}
          </select>
        </label>
        <label class="block text-sm"><span class="mb-1 block font-medium">Imagen</span><input name="imagen" type="file" accept="image/*" class={inputClass} /></label>
      </div>

      <div class="mt-6 flex justify-end gap-3 border-t border-slate-200 pt-4 dark:border-slate-800">
        <button type="button" data-modal-close class="rounded-md border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800">Cancelar</button>
        <button type="submit" class="inline-flex items-center gap-2 rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700 dark:bg-white dark:text-slate-950 dark:hover:bg-slate-200">
          <Icon name="lucide:save" class="h-4 w-4" />
          Guardar
        </button>
      </div>
    </form>
  </dialog>

  <DeleteDialog id="delete-modal" entity="producto" />
</AdminLayout>

<script>
  import { apiFetch } from '@/lib/csrf';
  import { bindDeleteDialog } from '@/lib/delete-dialog';

  const modal = document.getElementById('product-modal') as HTMLDialogElement;
  const form = document.getElementById('product-form') as HTMLFormElement;
  const title = document.querySelector<HTMLElement>('[data-form-title]');
  const idField = form.elements.namedItem('_id') as HTMLInputElement;

  function resetForm() {
    form.reset();
    idField.value = '';
    if (title) title.textContent = 'Nuevo producto';
  }

  function openProductModal() {
    if (typeof modal.showModal === 'function') modal.showModal();
  }

  document.querySelector('[data-open-create]')?.addEventListener('click', () => {
    resetForm();
    openProductModal();
  });

  document.querySelectorAll<HTMLElement>('[data-modal-close]').forEach((btn) => {
    btn.addEventListener('click', () => modal.close());
  });

  document.querySelectorAll<HTMLButtonElement>('[data-edit]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const d = btn.dataset;
      resetForm();
      idField.value = d.edit!;
      (form.elements.namedItem('nombre') as HTMLInputElement).value = d.nombre!;
      (form.elements.namedItem('precio') as HTMLInputElement).value = d.precio!;
      (form.elements.namedItem('stock') as HTMLInputElement).value = d.stock!;
      (form.elements.namedItem('mililitros') as HTMLInputElement).value = d.mililitros!;
      (form.elements.namedItem('categoria_id') as HTMLSelectElement).value = d.categoria!;
      if (title) title.textContent = `Editar producto`;
      openProductModal();
    });
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = idField.value;
    const fd = new FormData(form);
    fd.delete('_id');
    const imagen = fd.get('imagen') as File | null;
    if (!imagen || imagen.size === 0) fd.delete('imagen');

    const url = id ? `/api/products/${id}` : '/api/products';
    const method = id ? 'PUT' : 'POST';
    try {
      const res = await apiFetch(url, { method, body: fd });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error || 'Error al guardar');
      location.reload();
    } catch (err) {
      alert((err as Error).message);
    }
  });

  bindDeleteDialog({
    dialogId: 'delete-modal', endpoint: (id) => `/api/products/${id}`,
    fallbackName: 'Producto seleccionado', errorMessage: 'No se pudo eliminar',
  });
</script>
