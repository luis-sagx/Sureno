---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { Icon } from 'astro-icon/components';
import { apiServer } from '@/lib/api';

interface User {
  _id: string;
  nombre?: string;
  apellido?: string;
  email?: string;
  cedula?: string;
}

const res = await apiServer<User[]>('/api/users', Astro.request);
const clientes = res.data ?? [];
---

<AdminLayout title="Clientes — Sureño" active="clients">
  <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-slate-900 dark:text-white">Clientes</h1>
      <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Consulta los clientes registrados en la tienda.</p>
    </div>
    <span class="inline-flex items-center gap-2 rounded-md border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-600 shadow-sm dark:border-slate-800 dark:bg-slate-900 dark:text-slate-300">
      <Icon name="lucide:users" class="h-4 w-4" />
      {clientes.length} registrados
    </span>
  </div>

  {clientes.length === 0 ? (
    <div class="rounded-lg border border-dashed border-slate-300 bg-white p-10 text-center dark:border-slate-700 dark:bg-slate-900">
      <Icon name="lucide:user-round-x" class="mx-auto h-10 w-10 text-slate-400" />
      <p class="mt-3 font-medium">No hay clientes registrados.</p>
      <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Los clientes aparecerán aquí cuando creen una cuenta.</p>
    </div>
  ) : (
    <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm dark:border-slate-800 dark:bg-slate-900">
      <div class="overflow-x-auto">
        <table class="min-w-[640px] w-full text-left text-sm">
          <thead class="border-b border-slate-200 bg-slate-50 text-xs uppercase tracking-wide text-slate-500 dark:border-slate-800 dark:bg-slate-900/70 dark:text-slate-400">
            <tr>
              <th class="p-3">Cliente</th>
              <th class="p-3">Correo</th>
              <th class="p-3">Cédula</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
            {clientes.map((cliente) => (
              <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/40">
                <td class="p-3">
                  <div class="flex items-center gap-3">
                    <span class="grid h-9 w-9 place-items-center rounded-full bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-300">
                      <Icon name="lucide:user" class="h-4 w-4" />
                    </span>
                    <span class="font-medium text-slate-900 dark:text-white">
                      {cliente.nombre || 'Sin nombre'} {cliente.apellido || ''}
                    </span>
                  </div>
                </td>
                <td class="p-3 text-slate-600 dark:text-slate-300">{cliente.email || '—'}</td>
                <td class="p-3 text-slate-600 dark:text-slate-300">{cliente.cedula || '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  )}
</AdminLayout>
