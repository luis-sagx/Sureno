---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { Icon } from 'astro-icon/components';
import { apiServer } from '@/lib/api';
import DeleteDialog from '@/components/DeleteDialog.astro';

interface Order {
  _id: string;
  nombre_cliente: string;
  apellido_cliente: string;
  cedula_cliente: string;
  address_id: string;
  total: number;
  estado: string;
  fecha?: string;
}
const res = await apiServer<Order[]>('/api/orders', Astro.request);
const pedidos = [...(res.data ?? [])].sort((a, b) => {
  const dateA = a.fecha ? new Date(a.fecha).getTime() : 0;
  const dateB = b.fecha ? new Date(b.fecha).getTime() : 0;
  return dateB - dateA;
});
const estados = ['pendiente', 'enviado', 'entregado', 'cancelado'];
const formatDate = (value?: string) => {
  if (!value) return { date: '—', time: '' };
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return { date: value, time: '' };
  return {
    date: new Intl.DateTimeFormat('es-EC', { dateStyle: 'medium' }).format(date),
    time: new Intl.DateTimeFormat('es-EC', { timeStyle: 'short' }).format(date),
  };
};
---

<AdminLayout title="Pedidos — Sureño" active="orders">
  <div class="mb-6">
    <h1 class="text-2xl font-semibold text-slate-900 dark:text-white">Pedidos</h1>
    <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Actualiza estados y administra pedidos registrados.</p>
  </div>

  {pedidos.length === 0 ? (
    <div class="rounded-lg border border-dashed border-slate-300 bg-white p-10 text-center dark:border-slate-700 dark:bg-slate-900">
      <Icon name="lucide:clipboard-list" class="mx-auto h-10 w-10 text-slate-400" />
      <p class="mt-3 font-medium">No hay pedidos.</p>
      <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Los pedidos aparecerán aquí cuando los clientes compren.</p>
    </div>
  ) : (
    <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm dark:border-slate-800 dark:bg-slate-900">
      <div class="overflow-x-auto">
      <table class="min-w-[900px] w-full text-left text-sm">
        <thead class="border-b border-slate-200 bg-slate-50 text-xs uppercase tracking-wide text-slate-500 dark:border-slate-800 dark:bg-slate-900/70 dark:text-slate-400">
          <tr>
            <th class="p-3">Cliente</th>
            <th class="p-3">Fecha</th>
            <th class="p-3">Cédula</th>
            <th class="p-3">Total</th>
            <th class="p-3">Estado</th>
            <th class="p-3">Acciones</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
          {pedidos.map((o) => (
            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/40" data-row={o._id}>
              <td class="p-3">
                <div class="flex items-center gap-2">
                  <span class="grid h-8 w-8 place-items-center rounded-full bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-300">
                    <Icon name="lucide:user" class="h-4 w-4" />
                  </span>
                  <span>{o.nombre_cliente} {o.apellido_cliente}</span>
                </div>
              </td>
              <td class="p-3">
                <div class="font-medium text-slate-800 dark:text-slate-100">{formatDate(o.fecha).date}</div>
                <div class="text-xs text-slate-500 dark:text-slate-400">{formatDate(o.fecha).time}</div>
              </td>
              <td class="p-3">{o.cedula_cliente}</td>
              <td class="p-3 font-semibold">${Number(o.total).toFixed(2)}</td>
              <td class="p-3">
                <select
                  data-status={o._id}
                  class="rounded-md border border-slate-300 bg-white px-2 py-1 text-sm text-slate-900 outline-none focus:border-slate-500 focus:ring-2 focus:ring-slate-200 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100 dark:focus:ring-slate-800"
                >
                  {estados.map((e) => (
                    <option value={e} selected={e === o.estado}>{e}</option>
                  ))}
                </select>
              </td>
              <td class="p-3">
                <button data-del={o._id} data-del-name={`${o.nombre_cliente} ${o.apellido_cliente}`} class="inline-flex items-center gap-1.5 rounded-md border border-red-200 px-2.5 py-1.5 text-sm font-medium text-red-700 transition-colors hover:bg-red-50 dark:border-red-900/60 dark:text-red-300 dark:hover:bg-red-950/40">
                  <Icon name="lucide:trash-2" class="h-4 w-4" />
                  Eliminar
                </button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
      </div>
    </div>
  )}

  <DeleteDialog id="delete-order-modal" entity="pedido" />
</AdminLayout>

<script>
  import { apiFetch } from '@/lib/csrf';
  import { bindDeleteDialog } from '@/lib/delete-dialog';

  document.querySelectorAll<HTMLSelectElement>('[data-status]').forEach((sel) => {
    sel.addEventListener('change', async () => {
      const id = sel.dataset.status!;
      const res = await apiFetch(`/api/orders/${id}`, {
        method: 'PUT',
        body: JSON.stringify({ estado: sel.value }),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) alert(data.error || 'No se pudo actualizar');
    });
  });

  bindDeleteDialog({
    dialogId: 'delete-order-modal', endpoint: (id) => `/api/admin/orders/${id}`,
    fallbackName: 'Pedido seleccionado', errorMessage: 'No se pudo eliminar',
  });
</script>
