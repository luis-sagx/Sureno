---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { apiServer } from '@/lib/api';

interface Order {
  _id: string;
  nombre_cliente: string;
  apellido_cliente: string;
  cedula_cliente: string;
  address_id: string;
  total: number;
  estado: string;
}
const res = await apiServer<Order[]>('/api/orders', Astro.request);
const pedidos = res.data ?? [];
const estados = ['pendiente', 'enviado', 'entregado', 'cancelado'];
---

<AdminLayout title="Pedidos — Sureño" active="orders">
  <h1 class="brand-title mb-6 text-3xl">Administración de Pedidos</h1>

  {pedidos.length === 0 ? (
    <p class="card p-8 text-center opacity-80">No hay pedidos.</p>
  ) : (
    <div class="card overflow-x-auto">
      <table class="w-full text-left text-sm">
        <thead class="border-b border-black/10 text-xs uppercase opacity-60 dark:border-white/10">
          <tr>
            <th class="p-3">Cliente</th>
            <th class="p-3">Cédula</th>
            <th class="p-3">Total</th>
            <th class="p-3">Estado</th>
            <th class="p-3">Acciones</th>
          </tr>
        </thead>
        <tbody>
          {pedidos.map((o) => (
            <tr class="border-b border-black/5 dark:border-white/5" data-row={o._id}>
              <td class="p-3">{o.nombre_cliente} {o.apellido_cliente}</td>
              <td class="p-3">{o.cedula_cliente}</td>
              <td class="p-3 font-semibold">${Number(o.total).toFixed(2)}</td>
              <td class="p-3">
                <select
                  data-status={o._id}
                  class="rounded-lg border border-black/10 bg-white px-2 py-1 text-sm dark:border-white/15 dark:bg-white/5"
                >
                  {estados.map((e) => (
                    <option value={e} selected={e === o.estado}>{e}</option>
                  ))}
                </select>
              </td>
              <td class="p-3">
                <button data-del={o._id} class="text-red-600 hover:text-red-700">Eliminar</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</AdminLayout>

<script>
  import { apiFetch } from '@/lib/csrf';

  document.querySelectorAll<HTMLSelectElement>('[data-status]').forEach((sel) => {
    sel.addEventListener('change', async () => {
      const id = sel.dataset.status!;
      const res = await apiFetch(`/api/orders/${id}`, {
        method: 'PUT',
        body: JSON.stringify({ estado: sel.value }),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) alert(data.error || 'No se pudo actualizar');
    });
  });

  document.querySelectorAll<HTMLButtonElement>('[data-del]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.del!;
      if (!confirm('¿Eliminar este pedido?')) return;
      const res = await apiFetch(`/api/admin/orders/${id}`, { method: 'DELETE' });
      const data = await res.json().catch(() => ({}));
      if (res.ok) document.querySelector(`[data-row="${id}"]`)?.remove();
      else alert(data.error || 'No se pudo eliminar');
    });
  });
</script>
