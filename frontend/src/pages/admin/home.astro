---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { Icon } from 'astro-icon/components';
import { apiServer } from '@/lib/api';

interface Stats { total_clientes: number; total_productos: number; total_pedidos: number; }
interface Order { estado: string; }

const [statsRes, ordersRes] = await Promise.all([
  apiServer<Stats>('/api/admin/stats', Astro.request),
  apiServer<Order[]>('/api/orders', Astro.request),
]);
const s = statsRes.data ?? { total_clientes: 0, total_productos: 0, total_pedidos: 0 };
const pedidos = ordersRes.data ?? [];

const tiles = [
  { label: 'Clientes', value: s.total_clientes, icon: 'lucide:users', href: '/admin/clients', cta: 'Ver clientes' },
  { label: 'Productos', value: s.total_productos, icon: 'lucide:package', href: '/admin/products', cta: 'Ver productos' },
];

const estados = [
  {
    key: 'pendiente',
    label: 'Pendientes',
    icon: 'lucide:clock',
    cardClass: 'border-amber-200 bg-amber-50 dark:border-amber-900/60 dark:bg-amber-950/30',
    iconClass: 'bg-amber-100 text-amber-700 dark:bg-amber-900/50 dark:text-amber-300',
    titleClass: 'text-amber-800 dark:text-amber-200',
  },
  {
    key: 'enviado',
    label: 'Enviados',
    icon: 'lucide:truck',
    cardClass: 'border-sky-200 bg-sky-50 dark:border-sky-900/60 dark:bg-sky-950/30',
    iconClass: 'bg-sky-100 text-sky-700 dark:bg-sky-900/50 dark:text-sky-300',
    titleClass: 'text-sky-800 dark:text-sky-200',
  },
  {
    key: 'entregado',
    label: 'Entregados',
    icon: 'lucide:circle-check',
    cardClass: 'border-emerald-200 bg-emerald-50 dark:border-emerald-900/60 dark:bg-emerald-950/30',
    iconClass: 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/50 dark:text-emerald-300',
    titleClass: 'text-emerald-800 dark:text-emerald-200',
  },
  {
    key: 'cancelado',
    label: 'Cancelados',
    icon: 'lucide:circle-x',
    cardClass: 'border-rose-200 bg-rose-50 dark:border-rose-900/60 dark:bg-rose-950/30',
    iconClass: 'bg-rose-100 text-rose-700 dark:bg-rose-900/50 dark:text-rose-300',
    titleClass: 'text-rose-800 dark:text-rose-200',
  },
];

const countByState = estados.map((estado) => ({
  ...estado,
  value: pedidos.filter((p) => p.estado === estado.key).length,
}));
const otherOrders = Math.max(
  0,
  s.total_pedidos - countByState.reduce((total, estado) => total + estado.value, 0),
);
const statusTiles = otherOrders > 0
  ? [...countByState, {
      key: 'otros',
      label: 'Otros',
      icon: 'lucide:circle-help',
      value: otherOrders,
      cardClass: 'border-slate-200 bg-slate-50 dark:border-slate-800 dark:bg-slate-950',
      iconClass: 'bg-white text-slate-700 dark:bg-slate-900 dark:text-slate-200',
      titleClass: 'text-slate-700 dark:text-slate-200',
    }]
  : countByState;
---

<AdminLayout title="Dashboard — Sureño" active="home">
  <div class="mb-6">
    <h1 class="text-2xl font-semibold text-slate-900 dark:text-white">Dashboard</h1>
    <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Resumen general de la tienda.</p>
  </div>
  <div class="grid gap-5 md:grid-cols-2">
    {tiles.map(({ label, value, icon, href, cta }) => (
      <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md dark:border-slate-800 dark:bg-slate-900">
        <div class="flex h-full items-center justify-between gap-6">
          <div class="flex min-w-0 items-center gap-5">
            <span class="grid h-16 w-16 flex-none place-items-center rounded-lg bg-stone-100 text-stone-700 dark:bg-slate-800 dark:text-slate-200">
              <Icon name={icon} class="h-8 w-8" />
            </span>
            <div class="min-w-0">
              <p class="text-xl font-semibold text-slate-700 dark:text-slate-200">{label}</p>
              <p class="mt-2 text-4xl font-bold leading-none text-slate-950 dark:text-white">{value}</p>
            </div>
          </div>
          <a href={href} class="inline-flex flex-none items-center gap-1.5 rounded-md border border-slate-200 px-3 py-2 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-50 hover:text-slate-950 dark:border-slate-700 dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-white">
            {cta}
            <Icon name="lucide:arrow-right" class="h-4 w-4" />
          </a>
        </div>
      </div>
    ))}
  </div>

  <section class="mt-6 rounded-lg border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
    <div class="mb-5 flex flex-col gap-1 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <h2 class="text-2xl font-semibold text-slate-900 dark:text-white">Pedidos</h2>
        <p class=" text-slate-600 dark:text-slate-400">Total de pedidos registrados: {s.total_pedidos}</p>
      </div>
      <a href="/admin/orders" class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-600 hover:text-slate-950 dark:text-slate-300 dark:hover:text-white border border-slate-200 py-2 px-3 rounded-md hover:bg-slate-100/70">
        Ver pedidos
        <Icon name="lucide:arrow-right" class="h-4 w-4" />
      </a>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
      {statusTiles.map(({ label, value, icon, cardClass, iconClass, titleClass }) => (
        <div class:list={['rounded-lg border p-5', cardClass]}>
          <div class="flex items-center justify-between gap-3">
            <div>
              <p class:list={['text-base font-semibold', titleClass]}>{label}</p>
              <p class="mt-2 text-3xl font-bold leading-none text-slate-950 dark:text-white">{value}</p>
            </div>
            <span class:list={['grid h-12 w-12 flex-none place-items-center rounded-lg shadow-sm', iconClass]}>
              <Icon name={icon} class="h-6 w-6" />
            </span>
          </div>
        </div>
      ))}
    </div>
  </section>
</AdminLayout>
