---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { apiServer } from '@/lib/api';

interface Product {
  _id: string;
  nombre: string;
  descripcion?: string;
  precio: number;
  stock?: number;
  mililitros?: number;
  tipo?: string;
  imagen?: string;
}

const { id } = Astro.params;
const res = await apiServer<Product>(`/api/products/${id}`, Astro.request);
const p = res.data;

if (!res.ok || !p) {
  Astro.response.status = 404;
}
---

<BaseLayout title={p ? `Sureño — ${p.nombre}` : 'Producto no encontrado'}>
  {!p ? (
    <div class="card p-10 text-center">
      <h1 class="brand-title mb-2 text-2xl">Producto no encontrado</h1>
      <p class="mb-4 opacity-80">El producto que buscas no existe o fue retirado.</p>
      <a href="/products" class="btn-primary">Volver a productos</a>
    </div>
  ) : (
    <div class="grid gap-8 md:grid-cols-2">
      <div class="card grid place-items-center bg-white p-6">
        <img
          src={p.imagen || '/static/img/default-product.png'}
          alt={p.nombre}
          class="max-h-96 w-full object-contain"
          onerror="this.src='/static/img/default-product.png'"
        />
      </div>
      <div>
        <h1 class="brand-title text-3xl">{p.nombre}</h1>
        {p.descripcion && <p class="mt-3 opacity-90">{p.descripcion}</p>}
        <dl class="mt-4 space-y-1 text-sm">
          <div><dt class="inline font-semibold">Precio:</dt> <dd class="inline">${Number(p.precio).toFixed(2)}</dd></div>
          <div><dt class="inline font-semibold">Caja:</dt> <dd class="inline">12 unidades</dd></div>
          {p.stock != null && <div><dt class="inline font-semibold">Stock:</dt> <dd class="inline">{p.stock} cajas</dd></div>}
          {p.tipo && <div><dt class="inline font-semibold">Tipo:</dt> <dd class="inline">{p.tipo}</dd></div>}
          {p.mililitros && <div><dt class="inline font-semibold">Cantidad:</dt> <dd class="inline">{p.mililitros} ml</dd></div>}
        </dl>
        <div class="mt-6 flex flex-wrap gap-3">
          <button
            type="button"
            class="btn-primary"
            data-add
            data-id={p._id}
            data-nombre={p.nombre}
            data-precio={p.precio}
            data-imagen={p.imagen || '/static/img/default-product.png'}
            data-mililitros={p.mililitros ?? ''}
          >
            Agregar al carrito
          </button>
          <a href="/products" class="btn-secondary">← Volver a productos</a>
        </div>
      </div>
    </div>
  )}

  <div
    data-toast
    class="pointer-events-none fixed bottom-6 left-1/2 z-50 -translate-x-1/2 rounded-lg bg-brand-teal-dark px-4 py-2 text-sm text-white opacity-0 shadow-lg transition-opacity"
  >
  </div>
</BaseLayout>

<script>
  import { addToCart } from '@/lib/cart';

  const toast = document.querySelector<HTMLElement>('[data-toast]');
  function showToast(msg: string) {
    if (!toast) return;
    toast.textContent = msg;
    toast.style.opacity = '1';
    setTimeout(() => (toast.style.opacity = '0'), 1600);
  }

  document.querySelectorAll<HTMLButtonElement>('[data-add]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const d = btn.dataset;
      addToCart({
        id: d.id!,
        nombre: d.nombre!,
        precio: Number(d.precio),
        imagen: d.imagen!,
        mililitros: d.mililitros ? Number(d.mililitros) : undefined,
      });
      showToast(`${d.nombre} agregado al carrito`);
    });
  });
</script>
