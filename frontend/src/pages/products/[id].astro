---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { apiServer } from '@/lib/api';

interface Product {
  _id: string;
  nombre: string;
  descripcion?: string;
  precio: number;
  stock?: number;
  mililitros?: number;
  tipo?: string;
  imagen?: string;
}

const { id } = Astro.params;
const res = await apiServer<Product>(`/api/products/${id}`, Astro.request);
const p = res.data;
if (!res.ok || !p) Astro.response.status = 404;
---

<BaseLayout title={p ? `Sureño — ${p.nombre}` : 'Producto no encontrado'}>
  <div class="mx-auto max-w-6xl px-4 py-8">
    {!p ? (
      <div class="panel p-10 text-center">
        <h1 class="site-title mb-2 text-3xl">Producto no encontrado</h1>
        <p class="mb-4">El producto que buscas no existe o fue retirado.</p>
        <a href="/products" class="btn-1">Volver a productos</a>
      </div>
    ) : (
      <div class="grid gap-8 md:grid-cols-3">
        <div class="text-center md:col-span-1">
          <img
            src={p.imagen || '/static/img/producto.png'}
            alt={p.nombre}
            class="mx-auto max-h-[26rem] w-full rounded object-contain"
            onerror="this.src='/static/img/producto.png'"
          />
        </div>
        <div class="md:col-span-2">
          <h1 class="site-title my-2 text-4xl">{p.nombre}</h1>
          {p.descripcion && <p>{p.descripcion}</p>}
          <p class="mt-3"><strong>Precio:</strong> ${Number(p.precio).toFixed(2)}</p>
          <p><strong>Caja:</strong> 12 unidades</p>
          {p.stock != null && <p><strong>Stock disponible:</strong> {p.stock} cajas</p>}
          {p.tipo && <p><strong>Tipo:</strong> {p.tipo}</p>}
          {p.mililitros && <p><strong>Cantidad:</strong> {p.mililitros} ml</p>}

          <div class="mt-5 flex flex-wrap gap-3">
            <a href="/products" class="btn-1">← Volver a productos</a>
            <button
              type="button" class="btn-2" data-add
              data-id={p._id} data-nombre={p.nombre} data-precio={p.precio}
              data-imagen={p.imagen || '/static/img/producto.png'} data-mililitros={p.mililitros ?? ''}
            >
              Agregar al carrito
            </button>
          </div>
        </div>
      </div>
    )}
  </div>

  <div data-toast class="pointer-events-none fixed bottom-6 left-1/2 z-50 -translate-x-1/2 rounded-md px-4 py-2 text-white opacity-0 shadow-lg transition-opacity" style="background-color: var(--color-cafe)"></div>
</BaseLayout>

<script>
  import { addToCart } from '@/lib/cart';
  const toast = document.querySelector<HTMLElement>('[data-toast]');
  function showToast(msg: string) {
    if (!toast) return;
    toast.textContent = msg; toast.style.opacity = '1';
    setTimeout(() => (toast.style.opacity = '0'), 1600);
  }
  document.querySelectorAll<HTMLButtonElement>('[data-add]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const d = btn.dataset;
      addToCart({
        id: d.id!, nombre: d.nombre!, precio: Number(d.precio),
        imagen: d.imagen!, mililitros: d.mililitros ? Number(d.mililitros) : undefined,
      });
      showToast(`"${d.nombre}" agregado al carrito`);
    });
  });
</script>
