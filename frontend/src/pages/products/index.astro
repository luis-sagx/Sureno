---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { apiServer } from '@/lib/api';
import { UNIDADES_POR_CAJA } from '@/lib/config';
import CartToast from '@/components/CartToast.astro';

interface Product {
  _id: string;
  nombre: string;
  precio: number;
  mililitros?: number;
  imagen?: string;
}

const res = await apiServer<Product[]>('/api/products', Astro.request);
const productos = res.data ?? [];
const error = !res.ok;
---

<BaseLayout title="Sureño — Productos">
  <div class="mx-auto max-w-7xl px-3 py-8 sm:px-4">
    <h1 class="site-title my-4 text-center text-4xl">Productos Sureño</h1>

    {error && (
      <p class="panel p-6 text-center text-red-600">
        No se pudo cargar el catálogo. El servidor no esta disponible.
      </p>
    )}
    {!error && productos.length === 0 && (
      <p class="panel p-6 text-center">Aún no hay productos disponibles.</p>
    )}

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {productos.map((p) => (
        <div class="panel card-hover flex flex-col overflow-hidden rounded-lg">
          <div class="overflow-hidden border-b border-cafe/10 bg-white">
            <img
              src={p.imagen || '/static/img/producto.png'}
              alt={p.nombre}
              class="h-80 w-full object-contain p-2 transition-transform duration-300 hover:scale-105 sm:h-72 lg:h-80"
              onerror="this.src='/static/img/producto.png'"
            />
          </div>
          <div class="flex flex-1 flex-col bg-celeste/65 p-4 text-cafe dark:bg-white/5 dark:text-beige">
            <h5 class="text-xl font-bold leading-tight">{p.nombre}</h5>
            <p class="mt-2 text-sm text-cafe/85 dark:text-beige/80">Caja: {UNIDADES_POR_CAJA} unidades</p>
            <p class="mt-1 text-lg font-bold">Precio: ${Number(p.precio).toFixed(2)}</p>
            <button
              type="button"
              class="btn-2 mt-2 w-full"
              data-add
              data-id={p._id}
              data-nombre={p.nombre}
              data-precio={p.precio}
              data-imagen={p.imagen || '/static/img/producto.png'}
              data-mililitros={p.mililitros ?? ''}
            >
              <Icon name="lucide:shopping-cart" class="h-4 w-4" /> Agregar al carrito
            </button>
            <a href={`/products/${p._id}`} class="btn-1 mt-2 w-full">
              <Icon name="lucide:eye" class="h-4 w-4" /> Ver más información
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>

  <CartToast />
</BaseLayout>

<script>
  import { bindAddToCartButtons } from '@/lib/product-actions';
  bindAddToCartButtons();
</script>
