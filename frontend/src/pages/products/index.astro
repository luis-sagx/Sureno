---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { apiServer } from '@/lib/api';

interface Product {
  _id: string;
  nombre: string;
  precio: number;
  mililitros?: number;
  imagen?: string;
}

const res = await apiServer<Product[]>('/api/products', Astro.request);
const productos = res.data ?? [];
const error = !res.ok;
---

<BaseLayout title="Sureño — Productos">
  <div class="mx-auto max-w-6xl px-4 py-8">
    <h1 class="site-title my-4 text-center text-4xl">Productos Sureño</h1>

    {error && (
      <p class="panel p-6 text-center text-red-600">
        No se pudo cargar el catálogo. Verifica que el backend esté disponible.
      </p>
    )}
    {!error && productos.length === 0 && (
      <p class="panel p-6 text-center">Aún no hay productos disponibles.</p>
    )}

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {productos.map((p) => (
        <div class="section-2 flex flex-col overflow-hidden rounded-lg shadow-sm">
          <img
            src={p.imagen || '/static/img/producto.png'}
            alt={p.nombre}
            class="h-96 w-full object-cover"
            onerror="this.src='/static/img/producto.png'"
          />
          <div class="flex flex-1 flex-col p-4">
            <h5 class="text-lg font-bold">{p.nombre}</h5>
            <p class="mt-1 text-sm">Caja: 12 unidades</p>
            <p class="font-bold">Precio: ${Number(p.precio).toFixed(2)}</p>
            <button
              type="button"
              class="btn-2 mt-2 w-full"
              data-add
              data-id={p._id}
              data-nombre={p.nombre}
              data-precio={p.precio}
              data-imagen={p.imagen || '/static/img/producto.png'}
              data-mililitros={p.mililitros ?? ''}
            >
              Agregar al carrito
            </button>
            <a href={`/products/${p._id}`} class="btn-1 mt-2 w-full">Ver más información</a>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div data-toast class="pointer-events-none fixed bottom-6 left-1/2 z-50 -translate-x-1/2 rounded-md px-4 py-2 text-white opacity-0 shadow-lg transition-opacity" style="background-color: var(--color-cafe)"></div>
</BaseLayout>

<script>
  import { addToCart } from '@/lib/cart';
  const toast = document.querySelector<HTMLElement>('[data-toast]');
  function showToast(msg: string) {
    if (!toast) return;
    toast.textContent = msg;
    toast.style.opacity = '1';
    setTimeout(() => (toast.style.opacity = '0'), 1600);
  }
  document.querySelectorAll<HTMLButtonElement>('[data-add]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const d = btn.dataset;
      addToCart({
        id: d.id!, nombre: d.nombre!, precio: Number(d.precio),
        imagen: d.imagen!, mililitros: d.mililitros ? Number(d.mililitros) : undefined,
      });
      showToast(`"${d.nombre}" agregado al carrito`);
    });
  });
</script>
