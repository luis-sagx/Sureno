---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
---

<BaseLayout title="Sureño — Iniciar sesión" bare>
  <div class="section-1 w-full max-w-lg rounded-xl p-8 shadow-lg">
    <h1 class="site-title mb-6 text-center text-3xl">Iniciar sesión</h1>

    <p data-error class="mb-4 hidden rounded-md bg-red-100 px-3 py-2 text-red-700"></p>

    <form id="login-form" class="space-y-4" novalidate>
      <label class="block"><span class="mb-1 block">Correo</span>
        <input type="email" name="email" required autocomplete="email" class="field" /></label>
      <label class="block"><span class="mb-1 block">Contraseña</span>
        <input type="password" name="password" required autocomplete="current-password" class="field" /></label>
      <button type="submit" class="btn-2 w-full text-lg"><Icon name="lucide:log-in" class="h-5 w-5" /> Entrar</button>
    </form>

    <p class="mt-4 text-center">
      ¿No tienes cuenta? <a href="/signup" class="link">Regístrate</a>
    </p>
  </div>
</BaseLayout>

<script>
  import { apiFetch } from '@/lib/csrf';
  const form = document.getElementById('login-form') as HTMLFormElement;
  const errBox = document.querySelector<HTMLElement>('[data-error]');
  const showError = (m: string) => { if (errBox) { errBox.textContent = m; errBox.classList.remove('hidden'); } };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errBox?.classList.add('hidden');
    const fd = new FormData(form);
    const btn = form.querySelector('button[type=submit]') as HTMLButtonElement;
    btn.disabled = true;
    try {
      const res = await apiFetch('/api/login', {
        method: 'POST',
        body: JSON.stringify({ email: fd.get('email'), password: fd.get('password') }),
      });
      const data = await res.json().catch(() => ({}));
      if (res.ok) window.location.href = data.redirect || '/';
      else showError(data.error || 'No se pudo iniciar sesión');
    } catch {
      showError('Error de conexión con el servidor');
    } finally {
      btn.disabled = false;
    }
  });
</script>
