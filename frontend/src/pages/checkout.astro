---
import BaseLayout from '@/layouts/BaseLayout.astro';

const cantones = [
  'Quito', 'Cayambe', 'Mejía', 'Pedro Moncayo', 'Pedro Vicente Maldonado',
  'Puerto Quito', 'Rumiñahui', 'San Miguel de los Bancos',
];
---

<BaseLayout title="Sureño — Checkout">
  <div class="mx-auto max-w-6xl px-4 py-8">
    <div class="grid gap-6 lg:grid-cols-2">
      <!-- Dirección -->
      <form id="address-form" class="section-2 space-y-4 rounded p-6 shadow-sm" novalidate>
        <h1 class="site-title text-center text-2xl">Dirección de Entrega</h1>

        <label class="block"><span class="mb-1 block">Provincia</span>
          <input id="provincia" value="Pichincha" type="text" class="field" readonly /></label>
        <label class="block"><span class="mb-1 block">Cantón</span>
          <select id="canton" class="field" required>
            <option value="" disabled selected>Seleccione un cantón</option>
            {cantones.map((c) => <option value={c}>{c}</option>)}
          </select></label>
        <label class="block"><span class="mb-1 block">Parroquia</span><input id="parroquia" type="text" class="field" required /></label>
        <label class="block"><span class="mb-1 block">Calle Principal</span><input id="calle_principal" type="text" class="field" required /></label>
        <label class="block"><span class="mb-1 block">Calle Secundaria</span><input id="calle_secundaria" type="text" class="field" required /></label>
        <label class="block"><span class="mb-1 block">Código Postal</span><input id="codigo_postal" type="number" class="field" required /></label>

        <div class="text-center">
          <button type="submit" class="btn-2 text-lg">Guardar Dirección</button>
          <span data-address-ok class="ml-3 hidden text-green-700">✓ Dirección guardada</span>
        </div>
      </form>

      <!-- Resumen -->
      <div class="section-1 h-fit rounded p-6 text-lg shadow-sm">
        <h1 class="site-title mb-4 text-center text-2xl">Resumen de Compra</h1>
        <div class="mb-3 flex justify-between"><span>Subtotal</span><span data-subtotal>$0.00</span></div>
        <div class="mb-3 flex justify-between"><span>Costo de Envío</span><span>$3.00</span></div>
        <hr class="my-4 border-cafe/25" />
        <div class="flex justify-between font-bold"><span>Total</span><span data-total>$3.00</span></div>
        <button type="button" id="finalizar-compra" class="btn-1 mt-6 w-full text-lg disabled:opacity-50">
          Finalizar Compra
        </button>
        <p data-msg class="mt-3 hidden text-center"></p>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { apiFetch } from '@/lib/csrf';
  import { clearCart } from '@/lib/cart';

  const params = new URLSearchParams(location.search);
  const cartId = params.get('cart_id');
  let addressId: string | null = null;

  const $ = <T extends HTMLElement>(s: string) => document.querySelector<T>(s);
  const subtotalEl = $('[data-subtotal]');
  const totalEl = $('[data-total]');
  const okBadge = $('[data-address-ok]');
  const msg = $('[data-msg]');
  const finalizeBtn = $<HTMLButtonElement>('#finalizar-compra');

  if (!cartId) {
    location.href = '/cart';
  } else {
    fetch(`/api/cart/${cartId}`, { credentials: 'same-origin' })
      .then((r) => (r.ok ? r.json() : Promise.reject(new Error('carrito'))))
      .then((cart) => {
        if (subtotalEl) subtotalEl.textContent = `$${Number(cart.total).toFixed(2)}`;
        if (totalEl) totalEl.textContent = `$${(Number(cart.total) + 3).toFixed(2)}`;
      })
      .catch(() => { location.href = '/cart'; });
  }

  $('#address-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const body = {
      provincia: ($('#provincia') as HTMLInputElement).value,
      canton: ($('#canton') as HTMLInputElement).value,
      parroquia: ($('#parroquia') as HTMLInputElement).value,
      calle_principal: ($('#calle_principal') as HTMLInputElement).value,
      calle_secundaria: ($('#calle_secundaria') as HTMLInputElement).value,
      codigo_postal: ($('#codigo_postal') as HTMLInputElement).value,
    };
    try {
      const res = await apiFetch('/api/addresses', { method: 'POST', body: JSON.stringify(body) });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error || 'No se pudo guardar la dirección');
      addressId = data.id;
      okBadge?.classList.remove('hidden');
    } catch (err) {
      alert((err as Error).message);
    }
  });

  finalizeBtn?.addEventListener('click', async () => {
    if (!cartId || !addressId) {
      if (msg) { msg.textContent = 'Primero guarda tu dirección.'; msg.className = 'mt-3 text-center text-red-600'; }
      return;
    }
    finalizeBtn.disabled = true;
    try {
      const res = await apiFetch('/api/orders', {
        method: 'POST',
        body: JSON.stringify({ cart_id: cartId, address_id: addressId }),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error || 'No se pudo crear el pedido');
      clearCart();
      location.href = '/compras';
    } catch (err) {
      if (msg) { msg.textContent = (err as Error).message; msg.className = 'mt-3 text-center text-red-600'; }
      finalizeBtn.disabled = false;
    }
  });
</script>
