---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
---

<BaseLayout title="Sureño — Crear cuenta" bare>
  <div class="section-1 w-full max-w-xl rounded-xl p-8 shadow-lg">
    <h1 class="site-title mb-6 text-center text-3xl">Crear cuenta</h1>

    <p data-error class="mb-4 hidden rounded-md bg-red-100 px-3 py-2 text-red-700"></p>

    <form id="signup-form" class="space-y-4" novalidate>
      <div class="grid gap-4 sm:grid-cols-2">
        <label class="block"><span class="mb-1 block">Nombre</span><input type="text" name="nombre" required class="field" /></label>
        <label class="block"><span class="mb-1 block">Apellido</span><input type="text" name="apellido" required class="field" /></label>
      </div>
      <label class="block"><span class="mb-1 block">Cédula</span><input type="text" name="cedula" required inputmode="numeric" class="field" /></label>
      <label class="block"><span class="mb-1 block">Correo</span><input type="email" name="email" required autocomplete="email" class="field" /></label>
      <label class="block"><span class="mb-1 block">Contraseña</span><input type="password" name="password" required minlength="6" autocomplete="new-password" class="field" /></label>
      <button type="submit" class="btn-2 w-full text-lg"><Icon name="lucide:user-plus" class="h-5 w-5" /> Registrarme</button>
    </form>

    <p class="mt-4 text-center">
      ¿Ya tienes cuenta? <a href="/login" class="link">Inicia sesión</a>
    </p>
  </div>
</BaseLayout>

<script>
  import { bindJsonForm } from '@/lib/json-form';
  bindJsonForm({
    formId: 'signup-form', endpoint: '/api/signup', defaultRedirect: '/login',
    errorMessage: 'No se pudo completar el registro',
  });
</script>
