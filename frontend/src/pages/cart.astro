---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
---

<BaseLayout title="Sureño — Carrito">
  <div class="mx-auto max-w-3xl px-4 py-8">
    <div class="section-1 rounded p-6 shadow-sm">
      <h1 class="site-title mb-4 text-center text-3xl">Carrito de Compras</h1>

      <div data-cart-items class="flex flex-col gap-3"></div>
      <p data-empty class="hidden py-6 text-center">
        <Icon name="lucide:shopping-bag" class="mx-auto mb-2 h-8 w-8 opacity-70" />
        Tu carrito está vacío.
      </p>

      <hr class="my-4 border-cafe/20" />
      <div class="flex items-center justify-between">
        <h3 class="text-xl font-bold">Subtotal:</h3>
        <span data-total class="text-xl font-bold">$0.00</span>
      </div>

      <button type="button" data-checkout class="btn-1 mt-4 w-full text-lg disabled:opacity-50">
        <Icon name="lucide:check-circle-2" class="h-5 w-5" />
        Confirmar Productos
      </button>
      <a href="/products" class="link mt-3 flex items-center justify-center gap-2">
        <Icon name="lucide:arrow-left" class="h-4 w-4" />
        Seguir comprando
      </a>
    </div>
  </div>
</BaseLayout>

<script>
  import { getCart, saveCart, cartTotal, type CartItem } from '@/lib/cart';
  import { apiFetch } from '@/lib/csrf';

  const list = document.querySelector<HTMLElement>('[data-cart-items]');
  const empty = document.querySelector<HTMLElement>('[data-empty]');
  const totalEl = document.querySelector<HTMLElement>('[data-total]');
  const checkoutBtn = document.querySelector<HTMLButtonElement>('[data-checkout]');

  function render() {
    const cart = getCart();
    if (!list || !totalEl) return;
    totalEl.textContent = `$${cartTotal(cart).toFixed(2)}`;
    empty?.classList.toggle('hidden', cart.length > 0);
    if (checkoutBtn) checkoutBtn.disabled = cart.length === 0;

    list.innerHTML = '';
    cart.forEach((item, i) => {
      const row = document.createElement('div');
      row.className = 'flex items-center gap-4 rounded border border-cafe/15 bg-white/60 p-3 dark:bg-white/5';
      row.innerHTML = `
        <img src="${item.imagen}" alt="${item.nombre}" class="h-16 w-16 rounded object-cover" onerror="this.src='/static/img/producto.png'" />
        <div class="flex-1">
          <h2 class="font-bold">${item.nombre}</h2>
          ${item.mililitros ? `<p class="text-sm opacity-70">${item.mililitros} ml</p>` : ''}
          <span class="font-bold">$${(item.precio * item.cantidad).toFixed(2)}</span>
        </div>
        <div class="flex items-center gap-2">
          <button data-dec="${i}" class="btn-2 h-8 w-8 !px-0" aria-label="Menos">−</button>
          <span class="w-8 text-center">${item.cantidad}</span>
          <button data-inc="${i}" class="btn-2 h-8 w-8 !px-0" aria-label="Más">+</button>
        </div>
        <button data-del="${i}" class="ml-2 text-red-600 hover:text-red-700" aria-label="Eliminar">✕</button>`;
      list.appendChild(row);
    });
  }

  function change(index: number, delta: number) {
    const cart = getCart();
    const item = cart[index];
    if (!item) return;
    item.cantidad += delta;
    if (item.cantidad <= 0) cart.splice(index, 1);
    saveCart(cart);
    render();
  }
  function remove(index: number) {
    const cart = getCart();
    cart.splice(index, 1);
    saveCart(cart);
    render();
  }

  list?.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    if (t.dataset.inc != null) change(Number(t.dataset.inc), 1);
    else if (t.dataset.dec != null) change(Number(t.dataset.dec), -1);
    else if (t.dataset.del != null) remove(Number(t.dataset.del));
  });

  checkoutBtn?.addEventListener('click', async () => {
    const cart: CartItem[] = getCart();
    if (cart.length === 0) return;
    checkoutBtn.disabled = true;
    try {
      const res = await apiFetch('/api/cart', {
        method: 'POST',
        body: JSON.stringify({ productos: cart, total: cartTotal(cart) }),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error || 'No se pudo guardar el carrito');
      window.location.href = `/checkout?cart_id=${data.id}`;
    } catch (err) {
      alert((err as Error).message);
      checkoutBtn.disabled = false;
    }
  });

  render();
  window.addEventListener('cart:updated', render);
</script>
