---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Sureño — Carrito">
  <h1 class="brand-title mb-6 text-3xl">Tu carrito</h1>

  <div class="grid gap-8 lg:grid-cols-3">
    <div class="lg:col-span-2">
      <div data-cart-items class="space-y-4"></div>
      <p data-empty class="card hidden p-8 text-center opacity-80">Tu carrito está vacío.</p>
    </div>

    <aside class="card h-fit p-6">
      <h2 class="mb-4 text-lg font-semibold">Resumen</h2>
      <div class="flex justify-between border-b border-black/10 py-2 text-sm dark:border-white/10">
        <span>Total productos</span>
        <span data-total class="font-semibold">$0.00</span>
      </div>
      <button type="button" data-checkout class="btn-primary mt-6 w-full disabled:opacity-50">
        Proceder al pago
      </button>
      <a href="/products" class="mt-3 block text-center text-sm text-brand-teal-dark hover:underline dark:text-brand-teal-light">
        Seguir comprando
      </a>
    </aside>
  </div>
</BaseLayout>

<script>
  import { getCart, saveCart, cartTotal, type CartItem } from '@/lib/cart';
  import { apiFetch } from '@/lib/csrf';

  const list = document.querySelector<HTMLElement>('[data-cart-items]');
  const empty = document.querySelector<HTMLElement>('[data-empty]');
  const totalEl = document.querySelector<HTMLElement>('[data-total]');
  const checkoutBtn = document.querySelector<HTMLButtonElement>('[data-checkout]');

  function render() {
    const cart = getCart();
    if (!list || !totalEl) return;
    totalEl.textContent = `$${cartTotal(cart).toFixed(2)}`;
    empty?.classList.toggle('hidden', cart.length > 0);
    if (checkoutBtn) checkoutBtn.disabled = cart.length === 0;

    list.innerHTML = '';
    cart.forEach((item, i) => {
      const row = document.createElement('div');
      row.className = 'card flex items-center gap-4 p-4';
      row.innerHTML = `
        <img src="${item.imagen}" alt="${item.nombre}" class="h-16 w-16 rounded object-contain bg-white" onerror="this.src='/static/img/default-product.png'" />
        <div class="flex-1">
          <h3 class="font-semibold">${item.nombre}</h3>
          ${item.mililitros ? `<p class="text-xs opacity-70">${item.mililitros} ml</p>` : ''}
          <p class="mt-1 font-bold text-brand-teal-dark dark:text-brand-teal-light">$${(item.precio * item.cantidad).toFixed(2)}</p>
        </div>
        <div class="flex items-center gap-2">
          <button data-dec="${i}" class="btn-secondary h-8 w-8 !px-0" aria-label="Menos">−</button>
          <span class="w-8 text-center">${item.cantidad}</span>
          <button data-inc="${i}" class="btn-secondary h-8 w-8 !px-0" aria-label="Más">+</button>
        </div>
        <button data-del="${i}" class="ml-2 text-red-600 hover:text-red-700" aria-label="Eliminar">✕</button>`;
      list.appendChild(row);
    });
  }

  function change(index: number, delta: number) {
    const cart = getCart();
    const item = cart[index];
    if (!item) return;
    item.cantidad += delta;
    if (item.cantidad <= 0) cart.splice(index, 1);
    saveCart(cart);
    render();
  }
  function remove(index: number) {
    const cart = getCart();
    cart.splice(index, 1);
    saveCart(cart);
    render();
  }

  list?.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    if (t.dataset.inc != null) change(Number(t.dataset.inc), 1);
    else if (t.dataset.dec != null) change(Number(t.dataset.dec), -1);
    else if (t.dataset.del != null) remove(Number(t.dataset.del));
  });

  checkoutBtn?.addEventListener('click', async () => {
    const cart: CartItem[] = getCart();
    if (cart.length === 0) return;
    checkoutBtn.disabled = true;
    try {
      const res = await apiFetch('/api/cart', {
        method: 'POST',
        body: JSON.stringify({ productos: cart, total: cartTotal(cart) }),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error || 'No se pudo guardar el carrito');
      window.location.href = `/checkout?cart_id=${data.id}`;
    } catch (err) {
      alert((err as Error).message);
      checkoutBtn.disabled = false;
    }
  });

  render();
  window.addEventListener('cart:updated', render);
</script>
