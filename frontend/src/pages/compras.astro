---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { apiServer } from '@/lib/api';

interface Pedido {
  id: string;
  fecha_formateada: string;
  total: string;
  estado: string;
  productos: { nombre: string; cantidad: number }[];
  direccion: { provincia: string; canton: string; parroquia: string };
}

const res = await apiServer<Pedido[]>('/api/compras', Astro.request);
const pedidos = res.data ?? [];

const estadoClass: Record<string, string> = {
  pendiente: 'bg-amber-100 text-amber-800',
  cancelado: 'bg-red-100 text-red-700',
  entregado: 'bg-green-100 text-green-700',
};
---

<BaseLayout title="Sureño — Mis compras">
  <h1 class="brand-title mb-6 text-3xl">Mis compras</h1>

  {pedidos.length === 0 ? (
    <p class="card p-8 text-center opacity-80">Aún no tienes pedidos.</p>
  ) : (
    <div class="space-y-4">
      {pedidos.map((p) => (
        <article class="card p-6" data-order={p.id}>
          <div class="flex flex-wrap items-center justify-between gap-2">
            <div>
              <p class="text-sm opacity-70">{p.fecha_formateada}</p>
              <p class="text-lg font-bold text-brand-teal-dark dark:text-brand-teal-light">{p.total}</p>
            </div>
            <span class:list={['rounded-full px-3 py-1 text-xs font-semibold capitalize', estadoClass[p.estado] ?? 'bg-gray-100 text-gray-700']}>
              {p.estado}
            </span>
          </div>

          <div class="mt-3 grid gap-3 sm:grid-cols-2">
            <div>
              <h3 class="text-sm font-semibold">Productos</h3>
              <ul class="mt-1 text-sm opacity-80">
                {(p.productos || []).map((it) => (
                  <li>{it.cantidad ?? 1}× {it.nombre}</li>
                ))}
              </ul>
            </div>
            <div>
              <h3 class="text-sm font-semibold">Envío a</h3>
              <p class="mt-1 text-sm opacity-80">
                {p.direccion?.provincia}, {p.direccion?.canton}, {p.direccion?.parroquia}
              </p>
            </div>
          </div>

          {p.estado === 'pendiente' && (
            <div class="mt-4 text-right">
              <button type="button" class="btn-secondary" data-cancel={p.id}>Cancelar pedido</button>
            </div>
          )}
        </article>
      ))}
    </div>
  )}
</BaseLayout>

<script>
  import { apiFetch } from '@/lib/csrf';

  document.querySelectorAll<HTMLButtonElement>('[data-cancel]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.cancel!;
      if (!confirm('¿Cancelar este pedido?')) return;
      btn.disabled = true;
      try {
        const res = await apiFetch(`/api/orders/${id}/cancelar`, { method: 'PUT' });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || 'No se pudo cancelar');
        // Reflejar el cambio sin recargar
        const card = document.querySelector(`[data-order="${id}"]`);
        const badge = card?.querySelector('span');
        if (badge) {
          badge.textContent = 'cancelado';
          badge.className = 'rounded-full px-3 py-1 text-xs font-semibold capitalize bg-red-100 text-red-700';
        }
        btn.remove();
      } catch (err) {
        alert((err as Error).message);
        btn.disabled = false;
      }
    });
  });
</script>
