---
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import pacificoLatinUrl from '@fontsource/pacifico/files/pacifico-latin-400-normal.woff2?url';

interface Props {
  title?: string;
  description?: string;
  /** Página sin cabecera/pie (login, signup): contenido centrado. */
  bare?: boolean;
}

const {
  title = 'Sureño — Licores de calidad',
  description = 'Tienda de licores Sureño: catálogo, carrito y compras en línea.',
  bare = false,
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preload" href={pacificoLatinUrl} as="font" type="font/woff2" crossorigin />
    <script is:inline>
      (() => {
        const t = localStorage.getItem('theme');
        const dark = t ? t === 'dark' : matchMedia('(prefers-color-scheme: dark)').matches;
        if (dark) document.documentElement.classList.add('dark');
      })();
    </script>
  </head>
  <body class="flex min-h-screen flex-col">
    {bare ? (
      <main class="flex flex-1 items-center justify-center p-4">
        <slot />
      </main>
    ) : (
      <>
        <Header />
        <main class="flex-1">
          <slot />
        </main>
        <Footer />
      </>
    )}
  </body>
</html>
