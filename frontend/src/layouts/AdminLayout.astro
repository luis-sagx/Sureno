---
import '@/styles/global.css';
import { Icon } from 'astro-icon/components';
import pacificoLatinUrl from '@fontsource/pacifico/files/pacifico-latin-400-normal.woff2?url';

interface Props {
  title?: string;
  active?: 'home' | 'orders' | 'products';
}
const { title = 'Panel — Sureño', active = 'home' } = Astro.props;

const links = [
  { key: 'home', href: '/admin/home', label: 'Dashboard', icon: 'lucide:layout-dashboard' },
  { key: 'products', href: '/admin/products', label: 'Productos', icon: 'lucide:package' },
  { key: 'orders', href: '/admin/orders', label: 'Pedidos', icon: 'lucide:clipboard-list' },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="preload" href={pacificoLatinUrl} as="font" type="font/woff2" crossorigin />
    <script is:inline>
      (() => {
        const t = localStorage.getItem('theme');
        const dark = t ? t === 'dark' : matchMedia('(prefers-color-scheme: dark)').matches;
        if (dark) document.documentElement.classList.add('dark');
      })();
    </script>
  </head>
  <body class="flex min-h-screen">
    <aside class="flex w-60 flex-shrink-0 flex-col p-4 text-white" style="background-color: var(--color-cafe)">
      <a href="/" class="site-title mb-6 block text-center text-3xl !text-white">Sureño</a>
      <p class="mb-4 text-center text-xs uppercase tracking-wide text-white/60">Administración</p>
      <nav class="flex flex-col gap-1">
        {links.map(({ key, href, label, icon }) => (
          <a
            href={href}
            class:list={[
              'inline-flex items-center gap-2 rounded-md px-3 py-2 font-medium transition-colors hover:bg-white/10',
              key === active && 'bg-white/15',
            ]}
          >
            <Icon name={icon} class="h-4 w-4" />
            {label}
          </a>
        ))}
      </nav>
      <div class="mt-auto flex flex-col gap-2 pt-4">
        <button type="button" data-theme-toggle class="inline-flex items-center gap-2 rounded-md px-3 py-2 text-left text-sm hover:bg-white/10">
          <Icon name="lucide:sun-moon" class="h-4 w-4" />
          Cambiar tema
        </button>
        <button type="button" data-logout class="inline-flex items-center gap-2 rounded-md bg-red-700 px-3 py-2 text-sm font-medium hover:bg-red-800">
          <Icon name="lucide:log-out" class="h-4 w-4" />
          Cerrar sesión
        </button>
      </div>
    </aside>

    <main class="flex-1 overflow-x-auto bg-white p-6 dark:bg-[#1e1e1e]">
      <slot />
    </main>

    <script>
      import { apiFetch } from '@/lib/csrf';
      const root = document.documentElement;
      document.querySelector('[data-theme-toggle]')?.addEventListener('click', () => {
        root.classList.toggle('dark');
        localStorage.setItem('theme', root.classList.contains('dark') ? 'dark' : 'light');
      });
      document.querySelector('[data-logout]')?.addEventListener('click', async () => {
        try { await apiFetch('/api/logout', { method: 'POST' }); } catch {}
        window.location.href = '/login';
      });
    </script>
  </body>
</html>
