---
import { Icon } from 'astro-icon/components';
// Cabecera en una sola fila: marca + navegación + acciones de usuario.
const links = [
  { href: '/', label: 'Inicio', icon: 'lucide:home' },
  { href: '/about', label: 'Quiénes Somos', icon: 'lucide:users' },
  { href: '/products', label: 'Productos', icon: 'lucide:bottle-wine' },
  { href: '/contact', label: 'Contacto', icon: 'lucide:mail' },
];
const path = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---

<header class="bg-beige shadow-[0_2px_4px_rgba(0,0,0,0.1)] dark:bg-[#2b2a2a]">
  <div class="mx-auto flex max-w-7xl flex-wrap items-center justify-between gap-4 px-4 py-3">
    <!-- Marca -->
    <a href="/" class="flex items-center gap-3">
      <img src="/img/logo.png" alt="Logo Sureño" class="h-14 w-14 object-cover" onerror="this.style.display='none'" />
      <span class="site-title text-4xl leading-none">Sureño</span>
    </a>

    <!-- Navegación (misma fila) -->
    <nav class="order-3 w-full sm:order-none sm:w-auto">
      <ul class="flex flex-wrap items-center justify-center gap-1">
        {links.map(({ href, label, icon }) => (
          <li>
            <a
              href={href}
              aria-current={isActive(href) ? 'page' : undefined}
              class:list={[
                'inline-flex items-center gap-1.5 rounded-md px-3 py-2 font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-boton-celeste/50',
                isActive(href)
                  ? 'bg-celeste-dark text-white shadow-sm'
                  : 'text-cafe hover:bg-cafe/10 hover:text-celeste-dark dark:text-beige dark:hover:bg-white/10 dark:hover:text-celeste',
              ]}
            >
              <Icon name={icon} class="h-4 w-4" />
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Acciones -->
    <div class="flex items-center gap-3">
      <!-- Usuario -->
      <details class="relative">
        <summary class="grid h-10 w-10 cursor-pointer place-items-center rounded-full bg-boton-celeste text-white transition-colors hover:bg-boton-celeste-hover marker:content-none">
          <Icon name="lucide:user" class="h-5 w-5" />
          <span class="sr-only">Perfil</span>
        </summary>
        <div class="panel absolute right-0 z-20 mt-2 w-64 p-4 text-sm">
          <p class="site-title mb-2 text-lg">Perfil</p>
          <dl class="space-y-1">
            <div><dt class="inline font-semibold">Correo:</dt> <dd class="inline" data-user-email>--</dd></div>
            <div><dt class="inline font-semibold">Nombre:</dt> <dd class="inline" data-user-nombre>--</dd></div>
            <div><dt class="inline font-semibold">Apellido:</dt> <dd class="inline" data-user-apellido>--</dd></div>
          </dl>
          <hr class="my-3 border-cafe/15" />
          <a href="/compras" class="flex items-center justify-center gap-2 rounded-md px-2 py-1.5 hover:bg-celeste/30"><Icon name="lucide:receipt-text" class="h-4 w-4" /> Mis compras</a>
          <a href="/login" data-logout class="flex items-center justify-center gap-2 rounded-md px-2 py-1.5 hover:bg-celeste/30"><Icon name="lucide:log-out" class="h-4 w-4" /> Cerrar sesión</a>
        </div>
      </details>

      <!-- Carrito -->
      <a href="/cart" class="relative grid h-10 w-10 place-items-center rounded-full text-cafe transition-colors hover:bg-celeste/40 dark:text-beige" aria-label="Carrito">
        <Icon name="lucide:shopping-cart" class="h-6 w-6" />
        <span data-cart-count class="absolute -right-1 -top-1 hidden min-w-5 rounded-full bg-naranja px-1 text-center text-xs font-bold text-white shadow"></span>
      </a>

      <!-- Toggle de tema (switch con icono sol/luna) -->
      <button type="button" data-theme-toggle role="switch" aria-label="Cambiar tema"
        class="relative grid h-8 w-14 place-items-center rounded-full bg-cafe transition-colors dark:bg-beige">
        <span data-toggle-ball class="absolute left-[3px] top-1/2 grid h-6 w-6 -translate-y-1/2 place-items-center rounded-full bg-beige text-cafe transition-[left] dark:left-[29px] dark:bg-cafe dark:text-beige">
          <Icon name="lucide:sun" class="h-4 w-4 dark:hidden" />
          <Icon name="lucide:moon" class="hidden h-4 w-4 dark:block" />
        </span>
      </button>
    </div>
  </div>
</header>

<script>
  import { apiFetch } from '@/lib/csrf';

  // Tema
  const root = document.documentElement;
  document.querySelector('[data-theme-toggle]')?.addEventListener('click', () => {
    root.classList.toggle('dark');
    localStorage.setItem('theme', root.classList.contains('dark') ? 'dark' : 'light');
  });

  // Datos de usuario
  fetch('/api/user', { credentials: 'same-origin' })
    .then((r) => (r.ok ? r.json() : null))
    .then((u) => {
      if (!u || u.error) return;
      const set = (sel: string, v: string) => {
        const el = document.querySelector(sel);
        if (el) el.textContent = v;
      };
      set('[data-user-email]', u.email || '--');
      set('[data-user-nombre]', u.nombre || '--');
      set('[data-user-apellido]', u.apellido || '--');
    })
    .catch(() => {});

  // Logout
  document.querySelector('[data-logout]')?.addEventListener('click', async (e) => {
    e.preventDefault();
    try { await apiFetch('/api/logout', { method: 'POST' }); } catch {}
    localStorage.removeItem('cart');
    window.location.href = '/login';
  });

  // Contador de carrito
  function paintCart() {
    const badge = document.querySelector<HTMLElement>('[data-cart-count]');
    if (!badge) return;
    let count = 0;
    try {
      const cart = JSON.parse(localStorage.getItem('cart') || '[]');
      count = Array.isArray(cart) ? cart.reduce((n, i) => n + (i.cantidad || 1), 0) : 0;
    } catch {}
    badge.textContent = String(count);
    badge.classList.toggle('hidden', count === 0);
  }
  paintCart();
  window.addEventListener('storage', paintCart);
  window.addEventListener('cart:updated', paintCart);
</script>
