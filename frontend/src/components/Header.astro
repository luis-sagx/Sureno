---
// Cabecera: logo/marca, menú de usuario, carrito y toggle de tema.
---

<header class="bg-brand-cream/90 backdrop-blur dark:bg-brand-ink/90 border-b border-black/5 dark:border-white/10">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3">
    <!-- Marca -->
    <a href="/" class="flex items-center gap-3">
      <img src="/img/logo.png" alt="Logo Sureño" class="h-10 w-auto" onerror="this.style.display='none'" />
      <span class="brand-title text-2xl md:text-3xl">Sureño</span>
    </a>

    <div class="flex items-center gap-3">
      <!-- Menú de usuario -->
      <details class="relative">
        <summary class="grid h-10 w-10 cursor-pointer place-items-center rounded-full bg-brand-teal text-white marker:content-none">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" />
          </svg>
          <span class="sr-only">Perfil de usuario</span>
        </summary>
        <div class="card absolute right-0 z-20 mt-2 w-64 p-4 text-sm">
          <p class="mb-2 font-semibold text-brand-teal-dark dark:text-brand-teal-light">Perfil de Usuario</p>
          <dl class="space-y-1" data-user-panel>
            <div><dt class="inline font-medium">Correo:</dt> <dd class="inline" data-user-email>--</dd></div>
            <div><dt class="inline font-medium">Nombre:</dt> <dd class="inline" data-user-nombre>--</dd></div>
            <div><dt class="inline font-medium">Apellido:</dt> <dd class="inline" data-user-apellido>--</dd></div>
          </dl>
          <hr class="my-3 border-black/10 dark:border-white/10" />
          <a href="/compras" class="block rounded-md px-2 py-1.5 text-center hover:bg-brand-teal-light/20">Mis compras</a>
          <a href="/login" data-logout class="block rounded-md px-2 py-1.5 text-center hover:bg-brand-teal-light/20">Cerrar sesión</a>
        </div>
      </details>

      <!-- Carrito -->
      <a href="/cart" class="relative grid h-10 w-10 place-items-center rounded-full hover:bg-brand-teal-light/20" aria-label="Carrito">
        <svg class="h-5 w-5 text-brand-teal-dark dark:text-brand-teal-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="9" cy="21" r="1" /><circle cx="20" cy="21" r="1" />
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
        </svg>
        <span data-cart-count class="absolute -right-1 -top-1 hidden min-w-5 rounded-full bg-red-600 px-1 text-center text-xs font-semibold text-white"></span>
      </a>

      <!-- Toggle de tema -->
      <button type="button" data-theme-toggle class="grid h-10 w-10 place-items-center rounded-full hover:bg-brand-teal-light/20" aria-label="Cambiar tema">
        <svg data-icon-sun class="hidden h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
        </svg>
        <svg data-icon-moon class="hidden h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  import { apiFetch } from '@/lib/csrf';

  // --- Tema ---
  const root = document.documentElement;
  const sun = document.querySelector<HTMLElement>('[data-icon-sun]');
  const moon = document.querySelector<HTMLElement>('[data-icon-moon]');
  function paintThemeIcon() {
    const dark = root.classList.contains('dark');
    sun?.classList.toggle('hidden', !dark);
    moon?.classList.toggle('hidden', dark);
  }
  paintThemeIcon();
  document.querySelector('[data-theme-toggle]')?.addEventListener('click', () => {
    root.classList.toggle('dark');
    localStorage.setItem('theme', root.classList.contains('dark') ? 'dark' : 'light');
    paintThemeIcon();
  });

  // --- Datos de usuario ---
  fetch('/api/user', { credentials: 'same-origin' })
    .then((r) => (r.ok ? r.json() : null))
    .then((u) => {
      if (!u || u.error) return;
      const set = (sel: string, v: string) => {
        const el = document.querySelector(sel);
        if (el) el.textContent = v;
      };
      set('[data-user-email]', u.email || '--');
      set('[data-user-nombre]', u.nombre || '--');
      set('[data-user-apellido]', u.apellido || '--');
    })
    .catch(() => {});

  // --- Cerrar sesión ---
  document.querySelector('[data-logout]')?.addEventListener('click', async (e) => {
    e.preventDefault();
    try {
      await apiFetch('/api/logout', { method: 'POST' });
    } catch {}
    localStorage.removeItem('cart');
    window.location.href = '/login';
  });

  // --- Contador de carrito (localStorage) ---
  function paintCart() {
    const badge = document.querySelector<HTMLElement>('[data-cart-count]');
    if (!badge) return;
    let count = 0;
    try {
      const cart = JSON.parse(localStorage.getItem('cart') || '[]');
      count = Array.isArray(cart) ? cart.reduce((n, i) => n + (i.cantidad || 1), 0) : 0;
    } catch {}
    badge.textContent = String(count);
    badge.classList.toggle('hidden', count === 0);
  }
  paintCart();
  window.addEventListener('storage', paintCart);
  window.addEventListener('cart:updated', paintCart);
</script>
