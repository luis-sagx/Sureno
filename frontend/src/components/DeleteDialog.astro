---
import { Icon } from 'astro-icon/components';

interface Props {
  id: string;
  entity: string;
}

const { id, entity } = Astro.props;
---

<dialog id={id} class="fixed inset-0 m-auto max-h-[90vh] w-[min(92vw,420px)] overflow-y-auto rounded-lg border border-slate-200 bg-white p-0 text-slate-900 shadow-xl backdrop:bg-slate-950/50 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-100">
  <div class="p-6">
    <div class="flex gap-3">
      <span class="grid h-10 w-10 flex-none place-items-center rounded-full bg-red-100 text-red-700 dark:bg-red-950 dark:text-red-300">
        <Icon name="lucide:triangle-alert" class="h-5 w-5" />
      </span>
      <div>
        <h2 class="text-lg font-semibold">Eliminar {entity}</h2>
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Esta acción no se puede deshacer.</p>
        <p data-delete-name class="mt-3 font-medium"></p>
      </div>
    </div>
    <div class="mt-6 flex justify-end gap-3">
      <button type="button" data-delete-cancel class="rounded-md border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800">Cancelar</button>
      <button type="button" data-delete-confirm class="inline-flex items-center gap-2 rounded-md bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700">
        <Icon name="lucide:trash-2" class="h-4 w-4" />
        Eliminar
      </button>
    </div>
  </div>
</dialog>
