---
const social = [
  { href: 'https://www.facebook.com/licorsureno', label: 'Facebook', d: 'M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z' },
  { href: 'https://www.instagram.com/licores_sureno_ec/', label: 'Instagram', d: 'M12 2.2c3.2 0 3.6 0 4.9.1 3.3.1 4.8 1.7 4.9 4.9.1 1.3.1 1.6.1 4.8s0 3.5-.1 4.8c-.1 3.2-1.6 4.8-4.9 4.9-1.3.1-1.6.1-4.9.1s-3.6 0-4.9-.1c-3.3-.1-4.8-1.7-4.9-4.9C2.1 15.5 2.1 15.2 2.1 12s0-3.5.1-4.8C2.3 4 3.8 2.4 7.1 2.3 8.4 2.2 8.8 2.2 12 2.2zm0 3.2A6.6 6.6 0 1 0 18.6 12 6.6 6.6 0 0 0 12 5.4zm0 10.9A4.3 4.3 0 1 1 16.3 12 4.3 4.3 0 0 1 12 16.3zm6.9-11.1a1.5 1.5 0 1 0 1.5 1.5 1.5 1.5 0 0 0-1.5-1.5z' },
  { href: 'https://www.tiktok.com/@licores_sureno?lang=es', label: 'TikTok', d: 'M16 2c.3 2.2 1.6 3.9 3.8 4.2v3c-1.4 0-2.7-.4-3.8-1.1V15a6 6 0 1 1-6-6c.3 0 .7 0 1 .1v3.1a3 3 0 1 0 2 2.8V2z' },
];
---

<footer class="mt-16 bg-brand-teal-dark text-white">
  <div class="mx-auto max-w-6xl px-4 py-10">
    <div class="mb-8 text-center">
      <h3 class="brand-title text-2xl !text-white">Sobre Nosotros</h3>
      <p class="mx-auto mt-2 max-w-2xl text-sm text-white/80">
        Empresa dedicada a ofrecer licores de alta calidad a precios accesibles para todo el público.
      </p>
    </div>

    <div class="grid gap-8 sm:grid-cols-2">
      <div class="text-center sm:text-left">
        <h4 class="mb-2 font-semibold">Información de Contacto</h4>
        <ul class="space-y-1 text-sm text-white/80">
          <li>ventas@licorsureno.com</li>
          <li>Avenida Maldonado S29-106, Quito</li>
          <li>+593 96 796 7369</li>
        </ul>
      </div>
      <div class="text-center sm:text-right">
        <h4 class="mb-2 font-semibold">Síguenos</h4>
        <div class="flex justify-center gap-4 sm:justify-end">
          {social.map(({ href, label, d }) => (
            <a href={href} target="_blank" rel="noopener" aria-label={label} class="grid h-9 w-9 place-items-center rounded-full bg-white/10 hover:bg-white/20">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={d} /></svg>
            </a>
          ))}
        </div>
      </div>
    </div>

    <p class="mt-8 border-t border-white/10 pt-4 text-center text-xs text-white/60">
      © {new Date().getFullYear()} Licores Sureño. Todos los derechos reservados.
    </p>
  </div>
</footer>
