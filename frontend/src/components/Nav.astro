---
const links = [
  { href: '/', label: 'Inicio' },
  { href: '/about', label: 'Quiénes Somos' },
  { href: '/products', label: 'Productos' },
  { href: '/contact', label: 'Contacto' },
];
const path = Astro.url.pathname;
---

<nav class="bg-brand-teal-dark text-white">
  <div class="mx-auto flex max-w-6xl items-center justify-center gap-1 px-4 py-2">
    {links.map(({ href, label }) => {
      const active = href === '/' ? path === '/' : path.startsWith(href);
      return (
        <a
          href={href}
          class:list={[
            'rounded-md px-3 py-1.5 text-sm font-medium transition-colors hover:bg-white/10',
            active && 'bg-white/15',
          ]}
          aria-current={active ? 'page' : undefined}
        >
          {label}
        </a>
      );
    })}
  </div>
</nav>
